# Build / runtime
**/__pycache__/
*.pyc
.DS_Store
.venv/
venv/

# IDE — ignore personal state in .vscode/, but track the shared
# ``tasks.json`` so the **Start Home Assistant** task is the same
# for every contributor.
.vscode/*
!.vscode/tasks.json
.idea/
*.swp

# Claude Code runtime state — ``.claude/skills/`` is tracked, everything
# else under ``.claude/`` (session locks, …) is local-only.
.claude/*
!.claude/skills/
